#!/bin/bash

# 컴파일할 소스 파일명
SOURCE_FILE="grid.f90 init.f90 param.f90 postprocess.f90 solver.f90 main.f90"
# 생성할 실행 파일명
OUTPUT_FILE="main.exe"

# 빌드 모드 선택 (debug / release)
MODE=${1:-release}

if [ "$MODE" = "release" ]; then
    FLAGS="-O3 -ffree-line-length-none"
    echo "Mode: RELEASE"
else
    FLAGS="-O0 -g -fcheck=all -fbacktrace -Wall -Wextra -ffree-line-length-none"
    echo "Mode: DEBUG"
fi

echo "Compiling $SOURCE_FILE into $OUTPUT_FILE..."

gfortran $FLAGS $SOURCE_FILE -o $OUTPUT_FILE

if [ $? -eq 0 ]; then
    echo "------------------------------------------"
    echo "Compilation Successful! Running the program..."
    echo "------------------------------------------"
    ./$OUTPUT_FILE
else
    echo "Compilation Failed."
fi